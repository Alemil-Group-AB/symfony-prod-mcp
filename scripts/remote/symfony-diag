#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * symfony-diag (remote runner)
 *
 * Reads JSON from STDIN:
 *   {"action":"logs.tail","params":{"lines":200,"file":"prod.log"}}
 *
 * Writes JSON to STDOUT:
 *   {"ok":true,"output":"...","meta":{...}}
 *
 * Hardening notes:
 * - Only allowlisted actions are supported.
 * - Inputs are validated (length, charset, basenames only).
 * - Health URL is restricted to loopback (prevents SSRF / internal scanning).
 * - File reads are restricted to files that resolve under app root.
 * - SQL execution is read-only and allowlisted (SELECT/SHOW/EXPLAIN/DESCRIBE only).
 */

ini_set('display_errors', '0');
error_reporting(E_ALL);

const ENV_FILE = '/etc/symfony-diag.env';

function respond(bool $ok, string $output, array $meta = []): void {
  $payload = [
    'ok' => $ok,
    'output' => $output,
    'meta' => (object)$meta,
  ];
  fwrite(STDOUT, json_encode($payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n");
  exit($ok ? 0 : 1);
}

function loadEnvFile(string $path): void {
  if (!is_readable($path)) return;
  $lines = file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
  if ($lines === false) return;

  foreach ($lines as $line) {
    $line = trim($line);
    if ($line === '' || str_starts_with($line, '#')) continue;
    $pos = strpos($line, '=');
    if ($pos === false) continue;
    $key = trim(substr($line, 0, $pos));
    $val = trim(substr($line, $pos + 1));
    // Strip optional surrounding quotes
    if ((str_starts_with($val, '"') && str_ends_with($val, '"')) || (str_starts_with($val, "'") && str_ends_with($val, "'"))) {
      $val = substr($val, 1, -1);
    }
    if ($key !== '' && getenv($key) === false) {
      putenv($key . '=' . $val);
    }
  }
}

function envValue(string $key, ?string $default = null): ?string {
  $v = getenv($key);
  if ($v === false || $v === '') return $default;
  return $v;
}

function requireEnv(string $key): string {
  $v = envValue($key);
  if ($v === null) respond(false, "Missing required config: {$key}");
  return $v;
}

function truncate(string $s, int $maxChars): string {
  if ($maxChars <= 0) return '';
  if (mb_strlen($s) <= $maxChars) return $s;
  return mb_substr($s, 0, $maxChars) . "\n\n…(truncated)…";
}

function redact(string $s): string {
  // Best-effort redaction. This is NOT perfect.
  $patterns = [
    // Common framework secrets
    '/APP_KEY\s*=\s*base64:[A-Za-z0-9+\/=]{20,}/' => 'APP_KEY=base64:[REDACTED]',
    '/APP_KEY\s*=\s*[A-Za-z0-9+\/=]{20,}/' => 'APP_KEY=[REDACTED]',
    '/APP_SECRET\s*=\s*[^\s]{16,}/' => 'APP_SECRET=[REDACTED]',

    // Common env secrets / DSNs
    '/\b(AWS_SECRET_ACCESS_KEY|AWS_ACCESS_KEY_ID|AWS_SESSION_TOKEN)\s*=\s*[^\s]+/' => '$1=[REDACTED]',
    '/\b(DATABASE_URL|REDIS_URL|MAIL_URL|MAILER_DSN|MESSENGER_TRANSPORT_DSN|SENTRY_DSN)\s*=\s*[^\s]+/' => '$1=[REDACTED]',

    // Password-ish assignments
    '/(password|passwd|pwd)\s*[:=]\s*["\']?[^"\'>\s]+["\']?/i' => '$1=[REDACTED]',

    // Bearer tokens
    '/Authorization:\s*Bearer\s+[A-Za-z0-9\-_\.=]{10,}/i' => 'Authorization: Bearer [REDACTED]',
    '/Bearer\s+[A-Za-z0-9\-_\.=]{10,}/' => 'Bearer [REDACTED]',

    // JWT-ish blobs
    '/\beyJ[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+\b/' => '[REDACTED_JWT]',

    // Long hex tokens
    '/\b[a-f0-9]{32,}\b/i' => '[REDACTED_HEX]',
  ];

  foreach ($patterns as $re => $rep) {
    $s = preg_replace($re, $rep, $s) ?? $s;
  }
  return $s;
}

function isSafeBasename(?string $name): bool {
  if ($name === null) return true;
  if ($name === '' || strlen($name) > 128) return false;
  if (str_contains($name, '/') || str_contains($name, '\\')) return false;
  if (str_contains($name, "\0")) return false;
  // allow letters, numbers, dots, dashes, underscores
  return (bool)preg_match('/^[A-Za-z0-9._-]+$/', $name);
}

function findLatestLogFile(string $logDir): ?string {
  if (!is_dir($logDir)) return null;
  $files = glob($logDir . DIRECTORY_SEPARATOR . '*.log*');
  if (!$files) return null;

  $best = null;
  $bestMtime = -1;
  foreach ($files as $f) {
    if (!is_file($f)) continue;
    $m = filemtime($f);
    if ($m !== false && $m > $bestMtime) {
      $bestMtime = $m;
      $best = $f;
    }
  }
  return $best;
}

function resolveLogFile(string $logDir, ?string $basename): ?string {
  if (!is_dir($logDir)) return null;
  if ($basename === null || $basename === '') {
    return findLatestLogFile($logDir);
  }
  if (!isSafeBasename($basename)) return null;
  $path = $logDir . DIRECTORY_SEPARATOR . $basename;
  if (!is_file($path)) return null;
  // Ensure it's under logDir (defense-in-depth)
  $realDir = realpath($logDir);
  $realFile = realpath($path);
  if ($realDir === false || $realFile === false) return null;
  if (!str_starts_with($realFile, $realDir . DIRECTORY_SEPARATOR)) return null;
  return $realFile;
}

function resolveEnvFile(string $appDir, ?string $basename): ?string {
  $target = $basename ?? '.env';
  if (!isSafeBasename($target)) return null;

  // Allow `.env` and `.env.*` but refuse PHP-dumped env file by default.
  if (!preg_match('/^\.env(\.[A-Za-z0-9._-]+)?$/', $target)) return null;
  if (str_ends_with($target, '.php')) return null;

  $path = $appDir . DIRECTORY_SEPARATOR . $target;
  if (!is_file($path)) return null;

  $realDir = realpath($appDir);
  $realFile = realpath($path);
  if ($realDir === false || $realFile === false) return null;
  if ($realFile !== $realDir . DIRECTORY_SEPARATOR . $target) return null;
  if (!str_starts_with($realFile, $realDir . DIRECTORY_SEPARATOR)) return null;

  return $realFile;
}

function normalizeProjectRelativePath(string $relativePath): ?string {
  if ($relativePath === '' || strlen($relativePath) > 512) return null;
  if (str_contains($relativePath, "\0")) return null;

  $rel = trim(str_replace('\\', '/', $relativePath));
  if ($rel === '') return null;
  $rel = ltrim($rel, '/');
  if ($rel === '') $rel = '.';

  return $rel;
}

function resolveProjectPath(string $appDir, string $relativePath): ?string {
  $base = realpath($appDir);
  if ($base === false || !is_dir($base)) return null;

  $rel = normalizeProjectRelativePath($relativePath);
  if ($rel === null) return null;

  $candidate = ($rel === '.') ? $base : ($base . DIRECTORY_SEPARATOR . $rel);
  $resolved = realpath($candidate);
  if ($resolved === false) return null;

  if ($resolved !== $base && !str_starts_with($resolved, $base . DIRECTORY_SEPARATOR)) return null;
  return $resolved;
}

function projectRelativePath(string $appDir, string $absolutePath): ?string {
  $base = realpath($appDir);
  if ($base === false) return null;

  if ($absolutePath === $base) return '.';
  if (!str_starts_with($absolutePath, $base . DIRECTORY_SEPARATOR)) return null;
  return str_replace('\\', '/', substr($absolutePath, strlen($base) + 1));
}

function resolveProjectFile(string $appDir, string $relativePath): ?string {
  $resolved = resolveProjectPath($appDir, $relativePath);
  if ($resolved === null || !is_file($resolved)) return null;
  return $resolved;
}

function isSafeConnectionName(?string $name): bool {
  if ($name === null) return true;
  if ($name === '' || strlen($name) > 64) return false;
  return (bool)preg_match('/^[A-Za-z0-9._-]+$/', $name);
}

function normalizeReadOnlySql(string $query): ?string {
  if (str_contains($query, "\0")) return null;

  $trimmed = trim($query);
  if ($trimmed === '' || strlen($trimmed) > 5000) return null;

  // Allow at most one trailing ';' and reject multi-statement input.
  $withoutTrailing = rtrim($trimmed);
  if (str_ends_with($withoutTrailing, ';')) {
    $withoutTrailing = rtrim(substr($withoutTrailing, 0, -1));
  }
  if ($withoutTrailing === '' || str_contains($withoutTrailing, ';')) return null;

  if (!preg_match('/^\s*(SELECT|SHOW|EXPLAIN|DESCRIBE|DESC)\b/i', $withoutTrailing)) return null;

  // Defense-in-depth for read-only query edge cases.
  if (preg_match('/^\s*SELECT\b/i', $withoutTrailing)) {
    if (preg_match('/\bINTO\s+OUTFILE\b/i', $withoutTrailing)) return null;
    if (preg_match('/\bINTO\s+DUMPFILE\b/i', $withoutTrailing)) return null;
    if (preg_match('/\bFOR\s+UPDATE\b/i', $withoutTrailing)) return null;
    if (preg_match('/\bLOCK\s+IN\s+SHARE\s+MODE\b/i', $withoutTrailing)) return null;
  }

  return $withoutTrailing;
}

function encodeJsonPretty(array $payload): string {
  $encoded = json_encode(
    $payload,
    JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_PARTIAL_OUTPUT_ON_ERROR
  );
  if ($encoded === false) return 'Failed to encode output as JSON.';
  return $encoded;
}

function isLoopbackHost(string $host): bool {
  return $host === '127.0.0.1' || $host === 'localhost' || $host === '::1' || $host === '[::1]';
}

/**
 * Validate health URL.
 * - Always allows loopback hosts.
 * - Optionally allows ONE configured SNI host (used together with curl --resolve to loop back to 127.0.0.1).
 */
function isSafeLoopbackUrl(string $url, ?string $allowedSniHost = null): bool {
  $parts = parse_url($url);
  if ($parts === false) return false;

  $scheme = $parts['scheme'] ?? '';
  $host = $parts['host'] ?? '';
  if ($scheme !== 'http' && $scheme !== 'https') return false;

  if (isLoopbackHost($host)) return true;

  if ($allowedSniHost !== null && $allowedSniHost !== '' && $host === $allowedSniHost) {
    return true;
  }

  return false;
}

function runCommand(string $cmd, int $timeoutSec, int $maxOut): array {
  // Use proc_open so we can enforce timeout and capture stderr.
  $descriptorspec = [
    0 => ['pipe', 'r'],
    1 => ['pipe', 'w'],
    2 => ['pipe', 'w'],
  ];
  $process = proc_open($cmd, $descriptorspec, $pipes);
  if (!is_resource($process)) {
    return ['ok' => false, 'stdout' => '', 'stderr' => 'Failed to start process'];
  }

  fclose($pipes[0]);
  stream_set_blocking($pipes[1], false);
  stream_set_blocking($pipes[2], false);

  $stdout = '';
  $stderr = '';
  $start = microtime(true);

  while (true) {
    $status = proc_get_status($process);
    $stdout .= stream_get_contents($pipes[1]) ?: '';
    $stderr .= stream_get_contents($pipes[2]) ?: '';

    if (strlen($stdout) > $maxOut * 2 || strlen($stderr) > $maxOut * 2) {
      proc_terminate($process, 9);
      break;
    }

    if (!$status['running']) break;

    if ((microtime(true) - $start) > $timeoutSec) {
      proc_terminate($process, 9);
      $stderr .= "\n[timeout] exceeded {$timeoutSec}s";
      break;
    }
    usleep(50_000);
  }

  $stdout .= stream_get_contents($pipes[1]) ?: '';
  $stderr .= stream_get_contents($pipes[2]) ?: '';

  fclose($pipes[1]);
  fclose($pipes[2]);

  $exitCode = proc_close($process);

  $ok = ($exitCode === 0);
  return ['ok' => $ok, 'stdout' => $stdout, 'stderr' => $stderr, 'exitCode' => $exitCode];
}

function bootstrapSymfonyDoctrine(string $appDir): array {
  static $cache = [];
  if (isset($cache[$appDir])) return $cache[$appDir];

  $autoload = $appDir . DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR . 'autoload.php';
  if (!is_file($autoload)) {
    return $cache[$appDir] = ['ok' => false, 'error' => "Missing autoload file: {$autoload}"];
  }

  try {
    require_once $autoload;

    $kernelClass = envValue('SYMFONY_DIAG_KERNEL_CLASS', 'App\\Kernel') ?? 'App\\Kernel';
    $appEnv = envValue('SYMFONY_DIAG_APP_ENV', 'prod') ?? 'prod';
    $debugVal = strtolower(envValue('SYMFONY_DIAG_APP_DEBUG', '0') ?? '0');
    $appDebug = in_array($debugVal, ['1', 'true', 'yes', 'on'], true);

    if (!class_exists($kernelClass)) {
      // Common Symfony skeleton location.
      $kernelFile = $appDir . DIRECTORY_SEPARATOR . 'src' . DIRECTORY_SEPARATOR . 'Kernel.php';
      if (is_file($kernelFile)) {
        require_once $kernelFile;
      }
    }

    if (!class_exists($kernelClass)) {
      return $cache[$appDir] = ['ok' => false, 'error' => "Kernel class not found: {$kernelClass}. Set SYMFONY_DIAG_KERNEL_CLASS."];
    }

    $kernel = new $kernelClass($appEnv, $appDebug);
    if (!is_object($kernel) || !method_exists($kernel, 'boot') || !method_exists($kernel, 'getContainer')) {
      return $cache[$appDir] = ['ok' => false, 'error' => 'Failed to bootstrap Symfony kernel (unexpected Kernel API).'];
    }

    $kernel->boot();
    $container = $kernel->getContainer();
    if (!is_object($container)) {
      return $cache[$appDir] = ['ok' => false, 'error' => 'Symfony container unavailable after boot().'];
    }

    $hasDoctrine = false;
    if (method_exists($container, 'has')) {
      $hasDoctrine = (bool)$container->has('doctrine');
    } else {
      // Fallback: try get() and catch.
      $hasDoctrine = true;
    }

    if (!$hasDoctrine) {
      return $cache[$appDir] = ['ok' => false, 'error' => 'Doctrine service not found in container. Is doctrine/doctrine-bundle installed?'];
    }

    $doctrine = $container->get('doctrine');
    if (!is_object($doctrine)) {
      return $cache[$appDir] = ['ok' => false, 'error' => 'Doctrine service is not an object.'];
    }

    return $cache[$appDir] = [
      'ok' => true,
      'kernel' => $kernel,
      'container' => $container,
      'doctrine' => $doctrine,
      'env' => $appEnv,
      'debug' => $appDebug,
      'kernelClass' => $kernelClass,
    ];
  } catch (Throwable $e) {
    return $cache[$appDir] = ['ok' => false, 'error' => $e->getMessage()];
  }
}

function doctrineConnectionNames(object $doctrine): array {
  if (method_exists($doctrine, 'getConnectionNames')) {
    $names = $doctrine->getConnectionNames();
    if (is_array($names)) return array_keys($names);
  }
  if (method_exists($doctrine, 'getConnections')) {
    $conns = $doctrine->getConnections();
    if (is_array($conns)) return array_keys($conns);
  }
  // Fallback: try common default
  return ['default'];
}

function doctrineDefaultConnectionName(object $doctrine, array $names): string {
  if (method_exists($doctrine, 'getDefaultConnectionName')) {
    $v = $doctrine->getDefaultConnectionName();
    if (is_string($v) && $v !== '') return $v;
  }
  // Common fallback
  if (in_array('default', $names, true)) return 'default';
  return $names[0] ?? 'default';
}

function doctrineGetConnection(object $doctrine, string $name): object {
  if (method_exists($doctrine, 'getConnection')) {
    return $doctrine->getConnection($name);
  }
  // Fallback: try connections array
  if (method_exists($doctrine, 'getConnections')) {
    $conns = $doctrine->getConnections();
    if (is_array($conns) && isset($conns[$name]) && is_object($conns[$name])) return $conns[$name];
  }
  throw new RuntimeException("Doctrine connection not found: {$name}");
}

function doctrineDriverName(object $conn): ?string {
  if (method_exists($conn, 'getParams')) {
    $params = $conn->getParams();
    if (is_array($params)) {
      if (isset($params['driver']) && is_string($params['driver'])) return $params['driver'];
      if (isset($params['driverClass']) && is_string($params['driverClass'])) return $params['driverClass'];
    }
  }
  if (method_exists($conn, 'getDriver')) {
    $driver = $conn->getDriver();
    if (is_object($driver) && method_exists($driver, 'getName')) {
      $n = $driver->getName();
      if (is_string($n)) return $n;
    }
  }
  if (method_exists($conn, 'getDatabasePlatform')) {
    $plat = $conn->getDatabasePlatform();
    if (is_object($plat) && method_exists($plat, 'getName')) {
      $n = $plat->getName();
      if (is_string($n)) return $n;
    }
  }
  return null;
}

function doctrineSchemaManager(object $conn): object {
  if (method_exists($conn, 'createSchemaManager')) {
    return $conn->createSchemaManager();
  }
  if (method_exists($conn, 'getSchemaManager')) {
    return $conn->getSchemaManager();
  }
  throw new RuntimeException('Doctrine DBAL schema manager not available.');
}

function schemaListTableNames(object $sm): array {
  if (method_exists($sm, 'listTableNames')) {
    $names = $sm->listTableNames();
    return is_array($names) ? $names : [];
  }
  if (method_exists($sm, 'listTables')) {
    $tables = $sm->listTables();
    if (!is_array($tables)) return [];
    $out = [];
    foreach ($tables as $t) {
      if (is_object($t) && method_exists($t, 'getName')) {
        $out[] = (string)$t->getName();
      } elseif (is_string($t)) {
        $out[] = $t;
      }
    }
    return $out;
  }
  return [];
}

function columnToArray(object $col): array {
  $name = method_exists($col, 'getName') ? (string)$col->getName() : null;

  $type = null;
  if (method_exists($col, 'getType')) {
    $t = $col->getType();
    if (is_object($t) && method_exists($t, 'getName')) {
      $type = (string)$t->getName();
    } elseif (is_string($t)) {
      $type = $t;
    }
  }

  $out = [
    'name' => $name,
    'type' => $type,
  ];

  $map = [
    'length' => 'getLength',
    'precision' => 'getPrecision',
    'scale' => 'getScale',
    'unsigned' => 'getUnsigned',
    'fixed' => 'getFixed',
    'notnull' => 'getNotnull',
    'default' => 'getDefault',
    'autoincrement' => 'getAutoincrement',
    'comment' => 'getComment',
  ];
  foreach ($map as $k => $m) {
    if (method_exists($col, $m)) {
      $out[$k] = $col->$m();
    }
  }

  return $out;
}

function indexToArray(object $idx): array {
  $name = method_exists($idx, 'getName') ? (string)$idx->getName() : null;
  $cols = method_exists($idx, 'getColumns') ? $idx->getColumns() : null;
  if (!is_array($cols)) $cols = [];

  $out = [
    'name' => $name,
    'columns' => array_values(array_map('strval', $cols)),
  ];

  if (method_exists($idx, 'isUnique')) $out['unique'] = (bool)$idx->isUnique();
  if (method_exists($idx, 'isPrimary')) $out['primary'] = (bool)$idx->isPrimary();
  return $out;
}

function foreignKeyToArray(object $fk): array {
  $out = [];
  if (method_exists($fk, 'getName')) $out['name'] = $fk->getName();
  if (method_exists($fk, 'getLocalColumns')) $out['localColumns'] = $fk->getLocalColumns();
  if (method_exists($fk, 'getForeignTableName')) $out['foreignTable'] = $fk->getForeignTableName();
  if (method_exists($fk, 'getForeignColumns')) $out['foreignColumns'] = $fk->getForeignColumns();
  if (method_exists($fk, 'onUpdate')) $out['onUpdate'] = $fk->onUpdate();
  if (method_exists($fk, 'onDelete')) $out['onDelete'] = $fk->onDelete();
  return $out;
}

function safeCliName(?string $name): bool {
  if ($name === null) return true;
  if ($name === '' || strlen($name) > 64) return false;
  // No leading '-' to prevent injecting options.
  if (str_starts_with($name, '-')) return false;
  return (bool)preg_match('/^[A-Za-z0-9._-]+$/', $name);
}

// ---- Main ----

loadEnvFile(ENV_FILE);

$raw = stream_get_contents(STDIN);
if ($raw === false || trim($raw) === '') {
  respond(false, 'No input received. Expected JSON on STDIN.');
}

$data = json_decode($raw, true);
if (!is_array($data)) {
  respond(false, 'Invalid JSON input.');
}

$action = $data['action'] ?? ($data['cmd'] ?? null);
$params = $data['params'] ?? [];
if (!is_string($action) || $action === '') {
  respond(false, 'Missing action/cmd.');
}
if (!is_array($params)) $params = [];

// Backward compatibility: accept MCP tool-style names like "sys_info".
if (!str_contains($action, '.') && str_contains($action, '_')) {
  $parts = explode('_', $action, 2);
  if (count($parts) === 2 && $parts[0] !== '' && $parts[1] !== '') {
    $action = $parts[0] . '.' . $parts[1];
  }
}

$maxOutput = (int)(envValue('SYMFONY_DIAG_MAX_OUTPUT_CHARS', '200000') ?? '200000');
if ($maxOutput < 10000) $maxOutput = 10000;

$timeoutSec = (int)(envValue('SYMFONY_DIAG_TIMEOUT_SEC', '25') ?? '25');
if ($timeoutSec < 5) $timeoutSec = 5;
if ($timeoutSec > 120) $timeoutSec = 120;

$appDir = requireEnv('SYMFONY_DIAG_APP_DIR');
if (!is_dir($appDir)) respond(false, "Invalid app dir: {$appDir}");

$logDir = envValue('SYMFONY_DIAG_LOG_DIR', $appDir . '/var/log') ?? ($appDir . '/var/log');
$healthUrl = envValue(
  'SYMFONY_DIAG_READY_URL',
  envValue('SYMFONY_DIAG_HEALTH_URL', 'http://127.0.0.1:8000/ready'),
) ?? 'http://127.0.0.1:8000/ready';
$healthSniHost = envValue('SYMFONY_DIAG_HEALTH_SNI_HOST', null);
$healthInsecureVal = strtolower(envValue('SYMFONY_DIAG_HEALTH_INSECURE', '0') ?? '0');
$healthInsecure = in_array($healthInsecureVal, ['1', 'true', 'yes', 'on'], true);
$phpBin = envValue('SYMFONY_DIAG_PHP_BIN', 'php') ?? 'php';
$console = envValue('SYMFONY_DIAG_CONSOLE', $appDir . '/bin/console') ?? ($appDir . '/bin/console');

$kernelClass = envValue('SYMFONY_DIAG_KERNEL_CLASS', 'App\\Kernel') ?? 'App\\Kernel';
$appEnv = envValue('SYMFONY_DIAG_APP_ENV', 'prod') ?? 'prod';
$debugVal = strtolower(envValue('SYMFONY_DIAG_APP_DEBUG', '0') ?? '0');
$appDebug = in_array($debugVal, ['1', 'true', 'yes', 'on'], true);

$enableMutations = strtolower(envValue('SYMFONY_DIAG_ENABLE_MUTATIONS', '0') ?? '0');
$enableMutations = in_array($enableMutations, ['1', 'true', 'yes', 'on'], true);

$meta = [
  'action' => $action,
  'host' => php_uname('n'),
];

$out = '';
$ok = true;

switch ($action) {
  case 'health':
  case 'ready': {
    $url = $healthUrl;

    // Allow overriding the URL ONLY when the configured health URL is loopback (safe for dev).
    if (isset($params['url']) && is_string($params['url'])) {
      $cfgParts = parse_url($healthUrl);
      $cfgHost = (is_array($cfgParts) ? ($cfgParts['host'] ?? '') : '');
      if (isLoopbackHost($cfgHost) && isSafeLoopbackUrl($params['url'], null)) {
        $url = $params['url'];
      }
    }

    $parts = parse_url($url);
    if ($parts === false) {
      respond(false, 'Invalid health URL.', $meta);
    }

    $scheme = $parts['scheme'] ?? '';
    $host = $parts['host'] ?? '';
    $port = (int)($parts['port'] ?? (($scheme === 'https') ? 443 : 80));

