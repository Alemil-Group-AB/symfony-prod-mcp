# /etc/symfony-diag.env
# NOTE: This file should be readable ONLY by root (or a tightly scoped admin group).
# The diag runner itself can run without reading secrets; we use it for paths and policy flags.

# REQUIRED: absolute path to your Symfony app directory (project root where bin/console lives)
SYMFONY_DIAG_APP_DIR=/var/www/myapp/current

# Optional: log directory (default: $APP_DIR/var/log)
# SYMFONY_DIAG_LOG_DIR=/var/www/myapp/current/var/log

# Readiness endpoint
#
# If your server allows HTTP on loopback (recommended):
#   SYMFONY_DIAG_READY_URL=http://127.0.0.1:8000/ready
#
# If your server enforces HTTPS (no HTTP possible), use your real domain so the certificate matches,
# and the runner will force the TCP connection to stay local using curl --resolve:
#   SYMFONY_DIAG_READY_URL=https://example.com/ready
#   SYMFONY_DIAG_HEALTH_SNI_HOST=example.com
# Note: readiness checks ignore proxy env vars to keep checks loopback-local.
#
# Fallback only (less strict): if you must call https://127.0.0.1 with a mismatched/self-signed cert,
# enable insecure TLS for the readiness check only:
#   SYMFONY_DIAG_READY_URL=https://127.0.0.1/ready
#   SYMFONY_DIAG_HEALTH_INSECURE=1
SYMFONY_DIAG_READY_URL=http://127.0.0.1:8000/ready

# Backward compatibility (optional):
# SYMFONY_DIAG_HEALTH_URL=http://127.0.0.1:8000/ready

# Optional: explicitly allow ONE SNI host for the readiness check (used with --resolve to 127.0.0.1)
# SYMFONY_DIAG_HEALTH_SNI_HOST=example.com

# Optional: ignore TLS validation for the health check only (default 0)
# SYMFONY_DIAG_HEALTH_INSECURE=0

# Optional: php binary and console path
# SYMFONY_DIAG_PHP_BIN=/usr/bin/php
# SYMFONY_DIAG_CONSOLE=/var/www/myapp/current/bin/console

# Optional: Symfony kernel boot settings (defaults match Symfony skeleton)
# SYMFONY_DIAG_KERNEL_CLASS=App\\Kernel
# SYMFONY_DIAG_APP_ENV=prod
# SYMFONY_DIAG_APP_DEBUG=0

# Safety
SYMFONY_DIAG_TIMEOUT_SEC=25
SYMFONY_DIAG_MAX_OUTPUT_CHARS=200000

# Break-glass (default 0)
SYMFONY_DIAG_ENABLE_MUTATIONS=0
