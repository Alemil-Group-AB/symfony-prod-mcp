# /etc/symfony-diag.env
# NOTE: This file should be readable ONLY by root (or a tightly scoped admin group).
# The diag runner itself can run without reading secrets; we use it for paths and policy flags.

# REQUIRED: absolute path to your Symfony app directory (project root where bin/console lives)
SYMFONY_DIAG_APP_DIR=/var/www/myapp/current

# Optional: log directory (default: $APP_DIR/var/log)
# SYMFONY_DIAG_LOG_DIR=/var/www/myapp/current/var/log

# Optional: health endpoint URL (must be loopback)
SYMFONY_DIAG_HEALTH_URL=http://127.0.0.1/health

# Optional: php binary and console path
# SYMFONY_DIAG_PHP_BIN=/usr/bin/php
# SYMFONY_DIAG_CONSOLE=/var/www/myapp/current/bin/console

# Optional: Symfony kernel boot settings (defaults match Symfony skeleton)
# SYMFONY_DIAG_KERNEL_CLASS=App\\Kernel
# SYMFONY_DIAG_APP_ENV=prod
# SYMFONY_DIAG_APP_DEBUG=0

# Safety
SYMFONY_DIAG_TIMEOUT_SEC=25
SYMFONY_DIAG_MAX_OUTPUT_CHARS=200000

# Break-glass (default 0)
SYMFONY_DIAG_ENABLE_MUTATIONS=0
