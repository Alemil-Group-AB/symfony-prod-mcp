# Local MCP server config
SYMFONY_PROD_HOST=prod.example.com
SYMFONY_PROD_USER=codexdiag
SYMFONY_PROD_SSH_KEY=/home/alex/.ssh/codexdiag_ed25519

# Optional: if your SSH uses a non-default port
# SYMFONY_PROD_SSH_PORT=22

# Optional: remote command path (recommended when NOT using forced-command in authorized_keys)
# SYMFONY_PROD_REMOTE_COMMAND=/usr/local/bin/symfony-diag

# Optional: extra ssh options (space-separated), e.g. "-o StrictHostKeyChecking=accept-new -o ServerAliveInterval=30"
# SYMFONY_PROD_SSH_EXTRA_OPTS=

# Output safety limits
SYMFONY_PROD_MAX_OUTPUT_CHARS=200000
SYMFONY_PROD_TOOL_TIMEOUT_SEC=45

# Tool exposure policy (local-side extra guardrail)
# SYMFONY_PROD_ENABLE_MUTATIONS=0
